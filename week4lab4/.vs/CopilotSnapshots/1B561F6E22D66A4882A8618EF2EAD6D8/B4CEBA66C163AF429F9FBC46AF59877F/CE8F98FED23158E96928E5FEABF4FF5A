using System;
using System.Collections.Generic;
using System.Configuration;
using System.Data.SqlClient;
using System.Linq;
using System.Web;
using System.Web.UI;
using System.Web.UI.WebControls;

namespace week4lab4
{
    public partial class login : System.Web.UI.Page
    {
        protected void Page_Load(object sender, EventArgs e)
        {

        }

        protected void btnSignIn_Click(object sender, EventArgs e)
        {
            try
            {
                SqlConnection con = new SqlConnection(ConfigurationManager.ConnectionStrings["ConnectionString"].ConnectionString);
                con.Open();

                SqlCommand cmd = new SqlCommand("select count(*) from userTable where username = '" + uname.Text + "' and Password = '" + password.Text + "'", con);
                int count = Convert.ToInt32(cmd.ExecuteScalar().ToString());

                if (count > 0)
                {
                    SqlCommand cmdType = new SqlCommand("select fname, usertype from userTable where Username = '" + uname.Text + "'", con);
                    SqlDataReader dr = cmdType.ExecuteReader();

                    string type = "";
                    string name = "";

                    while (dr.Read())
                    {
                        type = dr["usertype"].ToString().Trim();
                        name = dr["fname"].ToString().Trim();
                    }

                    dr.Close();

                    Session["firstName"] = name;
                    Session["usertype"] = type;

                    con.Close();

                    if (type == "admin")
                        Response.Redirect("adminDashboard.aspx");
                    else if (type == "member")
                        Response.Redirect("memberDashboard.aspx");
                    else
                    {
                        errormsg.Visible = true;
                        errormsg.ForeColor = System.Drawing.Color.Red;
                        errormsg.Text = "Invalid user type!";
                    }
                }
                else
                {
                    errormsg.Visible = true;
                    errormsg.ForeColor = System.Drawing.Color.Red;
                    errormsg.Text = "Username and Password mismatch!";
                }
            }
            catch (Exception ex)
            {
                errormsg.Visible = true;
                errormsg.ForeColor = System.Drawing.Color.Red;
                errormsg.Text = "Error: " + ex.Message;
            }
        }

        protected void uname_TextChanged(object sender, EventArgs e)
        {

        }
    }
}